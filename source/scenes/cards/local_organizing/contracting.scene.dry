title: Award through Aurora firms
subtitle: Prosperity in Aurora; shareholders citywide take notice
on-arrival: {!
contract_wealthy_aurora = 1;
Q.rich_bump = 0.05;
if (typeof Q.addAsset === 'function') {
    Q.addAsset({ id: 'aurora_wealthy_contract_office', name: 'Aurora boutique contract office', district: 'Aurora', ownerType: 'stratum', owner: 'rich', kind: 'office', major: false });
}
