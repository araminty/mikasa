/** How radical the xenophobia is (0–1 linear, then sqrt above 1). Higher → harder for Dems to claw back. */
function effectiveParochialRadicalism(rad) {
    if (isNaN(rad) || rad <= 0) { return 0 }
    if (rad <= 1) { return rad }
    return Math.sqrt(rad)
}

/** Share of derived xenophobia Dems can claw off H (1 − radicalism, floored at 0). */
function demClawBackFraction(rad) {
    return Math.max(0, 1 - effectiveParochialRadicalism(rad))
}

/**
 * Derive modifier stacks from Q.parochialism (0–100).
 * xenophobia_derived: ramps above Suspicion (41+). H+/C− on 1st/2nd via catalog.
 * xenophobia_clawed_back: derived * demClawBackFraction(rad); C still hit by derived only.
 */
Q.syncParochialismXenophobiaStacks = function(q) {
    q = q || Q
    var p = Number(q.parochialism)
    if (isNaN(p)) { p = 0 }
    var rad = Number(q.parochial_radicalism)
    if (isNaN(rad)) { rad = 0.65 }
    var clawMult = demClawBackFraction(rad)

    var suspicionFloor = 41
    var maxStack = 20
    var raw = p <= suspicionFloor ? 0 : ((p - suspicionFloor) / (100 - suspicionFloor)) * maxStack

    q.xenophobia_derived = raw
    q.xenophobia_clawed_back = raw * clawMult
}

/** Opening syndicate prosperity sum (Families + Edges + Sharks @ 8 each). */
var SYNDICATE_WEALTH_BASELINE = 24
/** Sum if each syndicate prosperity hits clamp max (20). */
var SYNDICATE_WEALTH_MAX = 60

/**
 * Combined syndicate prosperity → drone_syndicate_wealth_bribe stack (citywide drone stratum).
 * Cheap abstention buys: G up, effective C down. Separate from crime/LE balance.
 * FUTURE: per-syndicate prosperity → separate puppet-party rows in catalog.
 */
Q.syncSyndicateDroneWealthStacks = function(q) {
    q = q || Q
    var f = Number(q.prosperity_families)
    var e = Number(q.prosperity_edges)
    var s = Number(q.prosperity_sharks)
    if (isNaN(f)) { f = 8 }
    if (isNaN(e)) { e = 8 }
    if (isNaN(s)) { s = 8 }
    var combined = f + e + s
    q.syndicate_combined_wealth = combined
    var span = SYNDICATE_WEALTH_MAX - SYNDICATE_WEALTH_BASELINE
    var raw = combined <= SYNDICATE_WEALTH_BASELINE
        ? 0
        : ((combined - SYNDICATE_WEALTH_BASELINE) / span) * 10
    q.drone_syndicate_wealth_bribe = raw
}

Q.applyElectorateModifiers = function() {
    var state = Q.electionV2
    if (!state) { return }

    Q.syncParochialismXenophobiaStacks(Q)
    Q.syncSyndicateDroneWealthStacks(Q)

    state.demographicsById = state.demographicsById || Object.fromEntries(
        state.demographics.map(function(d) { return [d.id, d] })
    )
    state.districtsById = state.districtsById || Object.fromEntries(
        state.districts.map(function(d) { return [d.id, d] })
    )

    // Districts are not rebuilt by syncAllVoteAppeals; reset from baseline each poll.
    for (var j = 0; j < state.districts.length; j++) {
        var dist = state.districts[j]
        dist.competitiveScores = electorateCopyScores(
            dist._baseCompetitiveScores || dist.competitiveScores
        )
    }
    // Strata/global already base+appeals from election runtime sync; add stack deltas only.

    for (var m = 0; m < Q.electorateModifierCatalog.length; m++) {
        Q.electorateModifierCatalog[m].apply(state, Q)
    }
}
// MIKASA_ELECTORATE_RUNTIME_END

electorate_runtime_ready = 1

