{!<span style="color: #44b88f;">Magrail Combine</span>!}: [+ cable_neg_stance_magrail : cable_neg_stance +] (leverage [+ magrail_leverage +], reprisal [+ magrail_reprisal +]).

{!<span style="color: #44b88f;">Brazos Zaibatsu</span>!}: [+ cable_neg_stance_brazos : cable_neg_stance +] (leverage [+ brazos_leverage +], reprisal [+ brazos_reprisal +]).

