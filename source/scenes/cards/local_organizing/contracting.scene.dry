Q.families_leverage = (Number(Q.families_leverage) || 0) + 1;
if (typeof Q.addAsset === 'function') {
    Q.addAsset({ id: 'pitts_coop_contract_workshop', name: 'Pitts coop guild workshop', district: 'Pitts', ownerType: 'stratum', owner: 'coop', kind: 'workshop', major: false });
