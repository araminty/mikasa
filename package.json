    "serve:dev": "node scripts/serve-dev.js",
    "lint:dendry": "node scripts/lint-dendry.js",
    "expand:ma": "node scripts/expand-ma-shorthand.js",
    "simulate-election": "node scripts/simulate-election.js",
    "simulate-election:v2": "node scripts/simulate-election.js --v2",
    "simulate-prosperity": "node scripts/simulate-prosperity-months.js",
    "optimize-prosperity": "node scripts/optimize-prosperity-balance.js",
    "export-landscape-geometry": "node scripts/export-landscape-geometry.js"
  },
  "repository": {
