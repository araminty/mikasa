@wd_disband
title: Withdraw disband-corp-security demand
choose-if: cable_neg_disband > 0
on-arrival: {!
Q.cableNegEnsureApi()
var d = Number(Q.cable_neg_disband) || 0
if (d === 1) {
    Q.cableNegReprisalSub('soylent', Q.CABLE_NEG_REPR_DISBAND_CITY_SOYLENT)
    Q.cableNegReprisalSub('magrail', Q.CABLE_NEG_REPR_DISBAND_CITY_MAGRAIL)
    Q.cableNegReprisalSub('brazos', Q.CABLE_NEG_REPR_DISBAND_CITY_BRAZOS)
} else if (d === 2) {
    Q.cableNegReprisalSub('soylent', Q.CABLE_NEG_REPR_DISBAND_MIL_SOYLENT)
    Q.cableNegReprisalSub('magrail', Q.CABLE_NEG_REPR_DISBAND_MIL_MAGRAIL)
    Q.cableNegReprisalSub('brazos', Q.CABLE_NEG_REPR_DISBAND_MIL_BRAZOS)
}
Q.cable_neg_disband = 0
if (typeof Q.syncIgAttitudes === 'function') { Q.syncIgAttitudes() }
!}
go-to: terms_menu

