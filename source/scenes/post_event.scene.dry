// new ElectorateModifier('_ref_Vats_C', 'district', 'Vats', 'C', 0.8),
// new ElectorateModifier('_ref_Vats_D', 'district', 'Vats', 'D', -0.3),
// new ElectorateModifier('_ref_Railyard_C', 'district', 'Railyard', 'C', 0.6),
// new ElectorateModifier('_ref_Railyard_G', 'district', 'Railyard', 'G', 0.1),
// new ElectorateModifier('_ref_Pitts_G', 'district', 'Pitts', 'G', 0.5),
// new ElectorateModifier('_ref_Pitts_D', 'district', 'Pitts', 'D', 0.2),
// new ElectorateModifier('_ref_Limelight_C', 'district', 'Limelight', 'C', 0.4),
// new ElectorateModifier('_ref_Limelight_G', 'district', 'Limelight', 'G', 0.3),
// new ElectorateModifier('_ref_Deeps_D', 'district', 'Deeps', 'D', 0.6),
// new ElectorateModifier('_ref_Deeps_I', 'district', 'Deeps', 'I', 0.4),
// new ElectorateModifier('_ref_Deeps_H', 'district', 'Deeps', 'H', -0.3),

Q.applyElectorateModifiers = function() {
    var state = Q.electionV2
    if (!state) { return }

    state.demographicsById = state.demographicsById || Object.fromEntries(
        state.demographics.map(function(d) { return [d.id, d] })
    )
    state.districtsById = state.districtsById || Object.fromEntries(
        state.districts.map(function(d) { return [d.id, d] })
    )

    for (var i = 0; i < state.demographics.length; i++) {
        var dem = state.demographics[i]
        dem.competitiveScores = electorateCopyScores(
            dem._baseCompetitiveScores || dem.competitiveScores
        )
    }
    for (var j = 0; j < state.districts.length; j++) {
        var dist = state.districts[j]
        dist.competitiveScores = electorateCopyScores(
            dist._baseCompetitiveScores || dist.competitiveScores
        )
    }
    state.global.competitiveScores = electorateCopyScores(
        state._baseGlobalScores || state.global.competitiveScores
    )

    for (var m = 0; m < Q.electorateModifierCatalog.length; m++) {
        Q.electorateModifierCatalog[m].apply(state, Q)
    }
}

Q.update_projections();

Q.has_event = 0;
// check if there are any cards in #event, and then go to main if not.
var scene = this.game.scenes['post_event.events_choice'];
var choices = this._compileChoices(scene);
if (choices && choices[0].title != "Continue...") {
    Q.has_event = 1;
} else {
    has_event = 0;
}
// pre-load all of the event images
if (this.ui && this.ui.show_portraits) {
    for (var choice of choices) {
        var cc = this.game.scenes[choice.id];
        if (cc.faceImage) {
            var im = new Image();
            im.url = cc.faceImage;
        }
    }
}

if (typeof window !== "undefined" && window.generateBar) {
}
!}
go-to: events_choice if has_event = 1; main if has_event = 0 and difficulty >= 0; main.main_easy if has_event = 0 and difficulty < 0

= [+ month : month +] [+ year +]

@events_choice

- #event

# Electorate modifiers: catalog above; stacks from Q[stackId] (several rows may share one stackId).
# Rebuilt at each Q.update_projections() (root.scene.dry).
