if (typeof Q.queueBudgetExpense === 'function') { Q.queueBudgetExpense(3, 'contract_award', 'Municipal contract award'); }
!}

Deepers' insulated workshops take contracts on their own terms — sealed bids, air-gapped ledgers, no corp middleware.  The district's prosperity tick rises without much fanfare outside the Deeps.

@coop_docks
title: Docks cooperatives and freight guilds
on-arrival: {!
contract_coop_docks = 1;
if (typeof Q.addAsset === 'function') {
    Q.addAsset({ id: 'docks_coop_contract_workshop', name: 'Docks coop contract workshop', district: 'Docks', ownerType: 'stratum', owner: 'coop', kind: 'workshop', major: false });
}
if (typeof Q.bumpDistrictProsperity === 'function') { Q.bumpDistrictProsperity('Docks', 0.05); }
if (typeof Q.queueBudgetExpense === 'function') { Q.queueBudgetExpense(3, 'contract_award', 'Municipal contract award'); }
