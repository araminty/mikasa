title: Post Event
new-page: true
on-arrival: {!

// --- Electorate modifiers (rebuilt before every poll in Q.update_projections) -------
// stackId: Q quality bumped in events (e.g. favor_second_wave_housing_dispute += 1).
// Several rows may share one stackId (multiple effects per choice).
// Dendry initializes missing qualities to 0 before +=. Each poll applies delta * stacks.
// Scopes: stratum (demographic), district (region), global.

var ELECTORATE_PARTY_KEYS = ['D', 'I', 'C', 'G', 'H']

function electorateZeroScores() {
    return { D: 0, I: 0, C: 0, G: 0, H: 0 }
}

function electorateCopyScores(src) {
    var out = electorateZeroScores()
    for (var i = 0; i < ELECTORATE_PARTY_KEYS.length; i++) {
        var k = ELECTORATE_PARTY_KEYS[i]
        out[k] = (src && src[k]) || 0
    }
    return out
}

function electorateAddDelta(scores, party, delta) {
    if (scores && scores[party] !== undefined) {
        scores[party] += delta
    }
}

var ELECTORATE_SCOPES = { stratum: 1, district: 1, global: 1 }

class ElectorateModifier {
    /**
     * Positional (table-friendly):
     *   new ElectorateModifier(rowId, stackId, scope, target, party, delta [, activeIf])
     *   new ElectorateModifier(stackId, scope, target, party, delta [, activeIf])  // legacy: rowId = stackId
     * stackId: Q quality for stacks (favor_second_wave_housing_dispute += 1).
     * scope: 'stratum' | 'district' | 'global' — use '' for target when global.
     * Object form: { id, stackId?, scope, target, party, delta, activeIf? }
     */
    constructor(rowId, stackId, scope, target, party, delta, activeIf) {
        var fromObject = rowId && typeof rowId === 'object'
        if (fromObject) {
            var opts = rowId
            rowId = opts.id
            stackId = opts.stackId != null ? opts.stackId : opts.id
            scope = opts.scope
            target = opts.target
            party = opts.party
            delta = opts.delta
            activeIf = opts.activeIf
            this.gateWithActiveIf = activeIf != null
        } else if (ELECTORATE_SCOPES[stackId]) {
            // legacy: (stackId, scope, target, party, delta [, activeIf])
            activeIf = delta
            delta = party
            party = target
            target = scope
            scope = stackId
            stackId = rowId
            this.gateWithActiveIf = arguments.length >= 6 && activeIf != null
        } else {
            this.gateWithActiveIf = arguments.length >= 7 && activeIf != null
        }
        this.id = rowId
        this.stackId = stackId || rowId
        this.scope = scope
        this.target = target || ''
        this.party = party
        this.delta = delta || 0
        this.activeIf = activeIf || function() { return true }
    }

    /** Stack count from Q[stackId]; non-numeric or <= 0 → no effect. */
    stacksFromQ(q) {
        if (!q || q[this.stackId] == null) { return 0 }
        var n = Number(q[this.stackId])
        if (isNaN(n) || n <= 0) { return 0 }
        return n
    }

    isActive(q) {
        try {
            return !!this.activeIf(q)
        } catch (e) {
            return false
        }
    }

    apply(state, q) {
        var stacks = this.stacksFromQ(q)
        if (stacks <= 0) { return }
        if (this.gateWithActiveIf && !this.isActive(q)) { return }
        var shift = this.delta * stacks
        if (this.scope === 'stratum') {
            var dem = state.demographicsById[this.target]
            if (dem) { electorateAddDelta(dem.competitiveScores, this.party, shift) }
        } else if (this.scope === 'district') {
            var dist = state.districtsById[this.target]
            if (dist) { electorateAddDelta(dist.competitiveScores, this.party, shift) }
        } else if (this.scope === 'global') {
            electorateAddDelta(state.global.competitiveScores, this.party, shift)
        }
    }
}

Q.ElectorateModifier = ElectorateModifier

// rowId | stackId (= Q) | scope | target | party | delta — target '' for global
// In events:  dundalk_reform += 1

Q.electorateModifierCatalog = [
    new ElectorateModifier('alien_dems_feb2300', 'stratum', 'alien', 'D', 0.2),
    new ElectorateModifier('pitts_gang_jun2300', 'district', 'Pitts', 'G', 0.3),
    new ElectorateModifier('refugee_pressure_hate', 'global', '', 'H', 0.1),
    new ElectorateModifier('dundalk_rally_reform', 'dundalk_reform', 'global', '', 'D', 1),
    new ElectorateModifier('dundalk_stake_rally_corp', 'dundalk_stakeholder', 'global', '', 'C', -2),
    new ElectorateModifier('dundalk_stake_rally_dems', 'dundalk_stakeholder', 'global', '', 'D', 1),
    new ElectorateModifier('dundalk_vigil_rally_gang', 'dundalk_vigil', 'global', '', 'G', -2),
    new ElectorateModifier('dundalk_vigil_rally_dems', 'dundalk_vigil', 'global', '', 'D', +.5),
    new ElectorateModifier('dundalk_nationalist_dems', 'dundalk_nationalist', 'global', '', 'D', +1.5),
    new ElectorateModifier('dundalk_nationalist_dems', 'dundalk_nationalist', 'global', '', 'H', +1.5),

    

    // --- organize_phase card stacks (placeholder; tune when cards are written) ---
    new ElectorateModifier('vocational_track_second_C', 'vocational_track', 'stratum', 'second', 'C', 0.15),
    new ElectorateModifier('vocational_track_second_D', 'vocational_track', 'stratum', 'second', 'D', 0.1),
    new ElectorateModifier('contract_outside_global_C', 'contract_outside', 'global', '', 'C', 0.1),
    new ElectorateModifier('contract_big3_drone_C', 'contract_big3', 'stratum', 'drone', 'C', 0.2),
    new ElectorateModifier('contract_petty_first_I', 'contract_petty', 'stratum', 'first', 'I', 0.1),
    new ElectorateModifier('contract_petty_first_G', 'contract_petty', 'stratum', 'first', 'G', 0.1),
    new ElectorateModifier('contract_coop_coop_D', 'contract_coop', 'stratum', 'coop', 'D', 0.15),
    new ElectorateModifier('coop_markets_coop_D', 'coop_markets', 'stratum', 'coop', 'D', 0.12),
    new ElectorateModifier('coop_markets_coop_C', 'coop_markets', 'stratum', 'coop', 'C', -0.08),
    new ElectorateModifier('coop_mother_coop_D', 'coop_mother', 'stratum', 'coop', 'D', 0.1),
    new ElectorateModifier('coop_mother_alien_D', 'coop_mother', 'stratum', 'alien', 'D', 0.08),
    new ElectorateModifier('coop_investment_coop_D', 'coop_investment', 'stratum', 'coop', 'D', 0.12),
    new ElectorateModifier('coop_investment_coop_C', 'coop_investment', 'stratum', 'coop', 'C', -0.1),
    new ElectorateModifier('magic_control_alien_C', 'magic_control', 'stratum', 'alien', 'C', 0.1),
    new ElectorateModifier('magic_control_alien_D', 'magic_control', 'stratum', 'alien', 'D', -0.1),
    new ElectorateModifier('magic_assimilate_alien_D', 'magic_assimilate', 'stratum', 'alien', 'D', 0.12),
    new ElectorateModifier('magic_school_alien_D', 'magic_school', 'stratum', 'alien', 'D', 0.15),
    new ElectorateModifier('magic_school_global_D', 'magic_school', 'global', '', 'D', 0.05),

    // --- otherworld event stacks (placeholder) ---
    new ElectorateModifier('otherworld_outpost_alien_D', 'otherworld_outpost', 'stratum', 'alien', 'D', 0.1),
    new ElectorateModifier('otherworld_outpost_global_C', 'otherworld_outpost', 'global', '', 'C', 0.08),
    new ElectorateModifier('great_protector_appease_global_C', 'great_protector_appeasement', 'global', '', 'C', 0.12),
    new ElectorateModifier('great_protector_appease_global_D', 'great_protector_appeasement', 'global', '', 'D', -0.05),
]


// --- Reference only: competitiveScores from root buildDemographics / buildDistricts ---
// Not in the live catalog. Real baselines live in root (_baseCompetitiveScores at init).
// Shown as modifiers so you can compare scales when authoring story stacks (delta * Q[stackId]).
//
// Strata (buildDemographics):
