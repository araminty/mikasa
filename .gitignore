# Whitelist: track only source/, .cursor/, and out/html/img/
# (plus this file). Everything else is ignored.

/*
!.gitignore
!robots.txt

!source/
!source/**

!.cursor/
!.cursor/**

# Local Cursor session logs (not part of the game repo)
.cursor/conversation-history/

!out/
out/*
!out/html/
out/html/*
!out/html/robots.txt
!out/html/img/
!out/html/img/**

# WSL / Windows Mark-of-the-Web sidecar files (e.g. image.jpg:Zone.Identifier)
**/*:Zone.Identifier
