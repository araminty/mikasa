    new ElectorateModifier('cable_raid_backlash_global_D', 'cable_syndicate_raid_backlash_global', 'global', '', 'D', -1.2),
    new ElectorateModifier('cable_raid_backlash_global_I', 'cable_syndicate_raid_backlash_global', 'global', '', 'I', 0.4),
    new ElectorateModifier('cable_raid_backlash_docks_D', 'cable_syndicate_raid_backlash_docks', 'district', 'Docks', 'D', -1),
    new ElectorateModifier('cable_raid_backlash_deeps_D', 'cable_syndicate_raid_backlash_deeps', 'district', 'Deeps', 'D', -0.8),
    new ElectorateModifier('cable_raid_backlash_railyard_D', 'cable_syndicate_raid_backlash_railyard', 'district', 'Railyard', 'D', -0.8),

    // Soylent raid — optional Seven Families joint patrols calm the Pitts a little.
    new ElectorateModifier('cable_pitts_patrol_calm_G', 'cable_soylent_pitts_patrol', 'district', 'Pitts', 'G', -0.15),
    new ElectorateModifier('cable_pitts_patrol_calm_D', 'cable_soylent_pitts_patrol', 'district', 'Pitts', 'D', 0.08),

]

