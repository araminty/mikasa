@finalize_deal
title: Close the bargain
on-arrival: {!
Q.cableNegEnsureApi()
Q.cableNegSyncPolicePayReprisal()
Q.cableNegAccepts = function(corp) {
    var L = Number(Q[corp + '_leverage']) || 0
    var R = Number(Q[corp + '_reprisal']) || 0
    return L > R ? 1 : 0
}
var votes = (
    Q.cableNegAccepts('soylent')
    + Q.cableNegAccepts('magrail')
    + Q.cableNegAccepts('brazos')
)
Q.cable_neg_votes = votes
Q.cable_neg_soylent_accepts = Q.cableNegAccepts('soylent')
Q.cable_neg_magrail_accepts = Q.cableNegAccepts('magrail')
Q.cable_neg_brazos_accepts = Q.cableNegAccepts('brazos')

if (votes >= 2) {
    Q.cable_neg_deal = 1
    Q.cable_break_peace = 1
    if (Q.cable_neg_civil_rights === 1) { Q.civil_rights_unlock = 1 }
    if (Q.cable_neg_police_vats === 1 || Q.cable_neg_police_railyard === 1 || Q.cable_neg_police_docks === 1 || Q.cable_neg_police_limelight === 1) {
        Q.corp_police_city_jurisdiction = 1
    }
    if (Q.cable_neg_police_pay_effective > 0) {
        Q.corp_police_pay_level = Q.cable_neg_police_pay_effective
    }
    if (Q.cable_neg_infra_cap > 0) {
        Q.corp_infra_cap = Q.cable_neg_infra_cap
    }
    if (Q.cable_neg_corp_tax > 0) {
        Q.corp_security_tax = Q.cable_neg_corp_tax
        Q.corp_security_tax_fund = Q.cable_neg_corp_tax_fund
        Q.brazos_security_tax_exempt = Q.cable_neg_brazos_tax_exempt
    }
    // TODO: apply budget revenue from corp_security_tax_fund × police payroll cost
    // TODO: set militia vs city replacement flags from cable_neg_disband
} else {
    Q.cable_neg_deal = 0
    Q.cable_break_peace = 0
}

if (Q.cable_neg_soylent_accepts === 0 && (Number(Q.soylent_reprisal) || 0) > (Number(Q.soylent_leverage) || 0)) {
    Q.soylent_leverage = Math.max(0, (Number(Q.soylent_leverage) || 0) - 1)
}
if (Q.cable_neg_magrail_accepts === 0 && (Number(Q.magrail_reprisal) || 0) > (Number(Q.magrail_leverage) || 0)) {
    Q.magrail_leverage = Math.max(0, (Number(Q.magrail_leverage) || 0) - 1)
}
if (Q.cable_neg_brazos_accepts === 0 && (Number(Q.brazos_reprisal) || 0) > (Number(Q.brazos_leverage) || 0)) {
    Q.brazos_leverage = Math.max(0, (Number(Q.brazos_leverage) || 0) - 1)
}
if (typeof Q.syncIgAttitudes === 'function') { Q.syncIgAttitudes() }
!}
go-to: deal_won if cable_neg_deal = 1; deal_failed if cable_neg_deal = 0

@deal_won
title: Ceasefire signed

[? if cable_neg_votes = 3: All three megacorps signed — a rare unanimous municipal victory. ?]
[? if cable_neg_votes = 2: Two megacorps signed; the holdout will remember what we extracted. ?]

The ceasefire holds on paper.  City enforcement begins where we demanded jurisdiction; the solar exchanges breathe easier for a day.

- @return

@deal_failed
title: Talks collapse

We could not get two megacorps to swallow the package — leverage fell short of reprisal.  Soylent [? if cable_neg_soylent_accepts = 1: signed ?][? if cable_neg_soylent_accepts = 0: walked ?]; Magrail [? if cable_neg_magrail_accepts = 1: signed ?][? if cable_neg_magrail_accepts = 0: walked ?]; Brazos [? if cable_neg_brazos_accepts = 1: signed ?][? if cable_neg_brazos_accepts = 0: walked ?].

Violence in the Vats and Railyard may continue until someone blinks.

- @return
