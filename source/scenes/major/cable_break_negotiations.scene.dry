title: Ceasefire Negotiations
subtitle: The megacorps need a referee — we set the price
max-visits: 1
new-page: true
tags: event
view-if: cable_break_negotiations_go = 1
on-arrival: {!
Q.cableNegEnsureApi = function() {
// --- reprisal knobs (edit here to rebalance demands) ---
// Leverage all three megacorps receive when negotiations open (accept if leverage > reprisal).
CABLE_NEG_LEVERAGE_BOOST = 3
// Reprisal on each megacorp shaved at the table opening (may go negative).
CABLE_NEG_OPENING_REPRISAL_RELIEF = 2

// Promise enticements — reprisal relief while bargaining; 2× back if broken later.
CABLE_NEG_PROMISE_BLIND_EYE_RELIEF = 2
CABLE_NEG_PROMISE_RAID_HEAT_RELIEF = 2
CABLE_NEG_PROMISE_DOCKS_DMZ_RELIEF = 2

// Police jurisdiction — reprisal on the corp that loses district security.
CABLE_NEG_REPR_VATS_SOYLENT = 2          // @take_vats_police
CABLE_NEG_REPR_RAILYARD_MAGRAIL = 2      // @take_railyard_police
CABLE_NEG_REPR_DOCKS_SOYLENT = 1           // @take_docks_police (each belligerent)
CABLE_NEG_REPR_DOCKS_MAGRAIL = 1
CABLE_NEG_REPR_LIMELIGHT_BRAZOS = 3      // @take_limelight_police (needs Vats/Railyard/Docks)

// Rival schadenfreude — reprisal lowered on corps that enjoy a rival's setback (always < gross raise).
CABLE_NEG_RELIEF_VATS_MAGRAIL = 1        // Magrail likes Soylent losing Vats security
CABLE_NEG_RELIEF_RAILYARD_SOYLENT = 1    // Soylent likes Magrail losing Railyard security
CABLE_NEG_RELIEF_DOCKS_BRAZOS = 1        // Brazos likes both belligerents grumbling over Docks
CABLE_NEG_RELIEF_LIMELIGHT_SOYLENT = 1   // Belligerents like Brazos humiliated on Limelight
CABLE_NEG_RELIEF_LIMELIGHT_MAGRAIL = 1
CABLE_NEG_RELIEF_TAX_BELL_BRAZOS = 1     // Brazos exempt / enjoys belligerents-only security tax
CABLE_NEG_RELIEF_TRIALS_MIXED_BRAZOS = 1 // Brazos likes city–corp panel binding the fighters

// Police payroll — reprisal on each megacorp when city absorbs corp security wages.
CABLE_NEG_REPR_PAY_2X_EACH = 1           // @pay_city_2x
CABLE_NEG_REPR_PAY_6X_EACH = 2           // @pay_city_6x
CABLE_NEG_REPR_PAY_6X_MATCH_EACH = 3     // @pay_city_6x_match (includes city police raise)
CABLE_NEG_REPR_PAY_10X_SOYLENT = 1       // @pay_corp_10x (match corp payscale — asymmetric)
CABLE_NEG_REPR_PAY_10X_MAGRAIL = 1
CABLE_NEG_REPR_PAY_10X_BRAZOS = 2

// Security tax — reprisal on taxed corps (requires payroll demand first).
CABLE_NEG_REPR_TAX_HALF_BELL_SOYLENT = 1   // @tax_half_belligerents
CABLE_NEG_REPR_TAX_HALF_BELL_MAGRAIL = 1
CABLE_NEG_REPR_TAX_FULL_BELL_SOYLENT = 2   // @tax_full_belligerents
CABLE_NEG_REPR_TAX_FULL_BELL_MAGRAIL = 2
CABLE_NEG_REPR_TAX_HALF_ALL_EACH = 1       // @tax_half_all_three
CABLE_NEG_REPR_TAX_FULL_ALL_SOYLENT = 1    // @tax_full_all_three
CABLE_NEG_REPR_TAX_FULL_ALL_MAGRAIL = 1
CABLE_NEG_REPR_TAX_FULL_ALL_BRAZOS = 2

// Disband corp security — reprisal on each megacorp (incompatible with jurisdiction transfer).
CABLE_NEG_REPR_DISBAND_CITY_SOYLENT = 3   // @disband_city_police
CABLE_NEG_REPR_DISBAND_CITY_MAGRAIL = 3
CABLE_NEG_REPR_DISBAND_CITY_BRAZOS = 2
CABLE_NEG_REPR_DISBAND_MIL_SOYLENT = 2     // @disband_militia
CABLE_NEG_REPR_DISBAND_MIL_MAGRAIL = 2
CABLE_NEG_REPR_DISBAND_MIL_BRAZOS = 1

// Civil rights — equal reprisal on all three (@demand_civil_rights).
CABLE_NEG_REPR_CIVIL_RIGHTS_EACH = 2

// Ceasefire trials — reprisal on corps that lose control of mercenary justice.
CABLE_NEG_REPR_TRIALS_CITY_SOYLENT = 2   // @trials_city_judges
CABLE_NEG_REPR_TRIALS_CITY_MAGRAIL = 2
CABLE_NEG_REPR_TRIALS_CITY_BRAZOS = 1
CABLE_NEG_REPR_TRIALS_MIXED_SOYLENT = 1  // @trials_mixed_panel
CABLE_NEG_REPR_TRIALS_MIXED_MAGRAIL = 1

// Judicial review — reprisal on all three (requires trial rules first).
CABLE_NEG_REPR_JUDGE_2_EACH = 1          // @review_2_city_3_corp
CABLE_NEG_REPR_JUDGE_4_EACH = 2          // @review_4_city_3_corp

// Infrastructure cap — reprisal on all three.
CABLE_NEG_REPR_INFRA_GENEROUS_EACH = 1   // @infra_cap_generous
CABLE_NEG_REPR_INFRA_FAIR_EACH = 2       // @infra_cap_fair

// Prior-leverage demands — reprisal on the targeted megacorp only.
CABLE_NEG_REPR_EDU_ENROLL_EACH = 1       // @demand_education_enroll_*
CABLE_NEG_REPR_EDU_PAY_EACH = 1          // @demand_education_pay_* (needs enrollment)
CABLE_NEG_REPR_LAND_TAX_EACH = 2         // @demand_land_tax_*

Q.cableNegLeverageBoost = CABLE_NEG_LEVERAGE_BOOST
Q.CABLE_NEG_REPR_VATS_SOYLENT = CABLE_NEG_REPR_VATS_SOYLENT
Q.CABLE_NEG_REPR_RAILYARD_MAGRAIL = CABLE_NEG_REPR_RAILYARD_MAGRAIL
Q.CABLE_NEG_REPR_DOCKS_SOYLENT = CABLE_NEG_REPR_DOCKS_SOYLENT
Q.CABLE_NEG_REPR_DOCKS_MAGRAIL = CABLE_NEG_REPR_DOCKS_MAGRAIL
Q.CABLE_NEG_REPR_LIMELIGHT_BRAZOS = CABLE_NEG_REPR_LIMELIGHT_BRAZOS
Q.CABLE_NEG_RELIEF_VATS_MAGRAIL = CABLE_NEG_RELIEF_VATS_MAGRAIL
Q.CABLE_NEG_RELIEF_RAILYARD_SOYLENT = CABLE_NEG_RELIEF_RAILYARD_SOYLENT
Q.CABLE_NEG_RELIEF_DOCKS_BRAZOS = CABLE_NEG_RELIEF_DOCKS_BRAZOS
Q.CABLE_NEG_RELIEF_LIMELIGHT_SOYLENT = CABLE_NEG_RELIEF_LIMELIGHT_SOYLENT
Q.CABLE_NEG_RELIEF_LIMELIGHT_MAGRAIL = CABLE_NEG_RELIEF_LIMELIGHT_MAGRAIL
Q.CABLE_NEG_RELIEF_TAX_BELL_BRAZOS = CABLE_NEG_RELIEF_TAX_BELL_BRAZOS
Q.CABLE_NEG_RELIEF_TRIALS_MIXED_BRAZOS = CABLE_NEG_RELIEF_TRIALS_MIXED_BRAZOS
Q.CABLE_NEG_REPR_PAY_2X_EACH = CABLE_NEG_REPR_PAY_2X_EACH
Q.CABLE_NEG_REPR_PAY_6X_EACH = CABLE_NEG_REPR_PAY_6X_EACH
Q.CABLE_NEG_REPR_PAY_6X_MATCH_EACH = CABLE_NEG_REPR_PAY_6X_MATCH_EACH
Q.CABLE_NEG_REPR_PAY_10X_SOYLENT = CABLE_NEG_REPR_PAY_10X_SOYLENT
Q.CABLE_NEG_REPR_PAY_10X_MAGRAIL = CABLE_NEG_REPR_PAY_10X_MAGRAIL
Q.CABLE_NEG_REPR_PAY_10X_BRAZOS = CABLE_NEG_REPR_PAY_10X_BRAZOS
Q.CABLE_NEG_REPR_TAX_HALF_BELL_SOYLENT = CABLE_NEG_REPR_TAX_HALF_BELL_SOYLENT
Q.CABLE_NEG_REPR_TAX_HALF_BELL_MAGRAIL = CABLE_NEG_REPR_TAX_HALF_BELL_MAGRAIL
Q.CABLE_NEG_REPR_TAX_FULL_BELL_SOYLENT = CABLE_NEG_REPR_TAX_FULL_BELL_SOYLENT
Q.CABLE_NEG_REPR_TAX_FULL_BELL_MAGRAIL = CABLE_NEG_REPR_TAX_FULL_BELL_MAGRAIL
Q.CABLE_NEG_REPR_TAX_HALF_ALL_EACH = CABLE_NEG_REPR_TAX_HALF_ALL_EACH
Q.CABLE_NEG_REPR_TAX_FULL_ALL_SOYLENT = CABLE_NEG_REPR_TAX_FULL_ALL_SOYLENT
Q.CABLE_NEG_REPR_TAX_FULL_ALL_MAGRAIL = CABLE_NEG_REPR_TAX_FULL_ALL_MAGRAIL
Q.CABLE_NEG_REPR_TAX_FULL_ALL_BRAZOS = CABLE_NEG_REPR_TAX_FULL_ALL_BRAZOS
Q.CABLE_NEG_REPR_DISBAND_CITY_SOYLENT = CABLE_NEG_REPR_DISBAND_CITY_SOYLENT
Q.CABLE_NEG_REPR_DISBAND_CITY_MAGRAIL = CABLE_NEG_REPR_DISBAND_CITY_MAGRAIL
Q.CABLE_NEG_REPR_DISBAND_CITY_BRAZOS = CABLE_NEG_REPR_DISBAND_CITY_BRAZOS
Q.CABLE_NEG_REPR_DISBAND_MIL_SOYLENT = CABLE_NEG_REPR_DISBAND_MIL_SOYLENT
Q.CABLE_NEG_REPR_DISBAND_MIL_MAGRAIL = CABLE_NEG_REPR_DISBAND_MIL_MAGRAIL
Q.CABLE_NEG_REPR_DISBAND_MIL_BRAZOS = CABLE_NEG_REPR_DISBAND_MIL_BRAZOS
Q.CABLE_NEG_REPR_CIVIL_RIGHTS_EACH = CABLE_NEG_REPR_CIVIL_RIGHTS_EACH
Q.CABLE_NEG_REPR_TRIALS_CITY_SOYLENT = CABLE_NEG_REPR_TRIALS_CITY_SOYLENT
Q.CABLE_NEG_REPR_TRIALS_CITY_MAGRAIL = CABLE_NEG_REPR_TRIALS_CITY_MAGRAIL
Q.CABLE_NEG_REPR_TRIALS_CITY_BRAZOS = CABLE_NEG_REPR_TRIALS_CITY_BRAZOS
Q.CABLE_NEG_REPR_TRIALS_MIXED_SOYLENT = CABLE_NEG_REPR_TRIALS_MIXED_SOYLENT
Q.CABLE_NEG_REPR_TRIALS_MIXED_MAGRAIL = CABLE_NEG_REPR_TRIALS_MIXED_MAGRAIL
Q.CABLE_NEG_REPR_JUDGE_2_EACH = CABLE_NEG_REPR_JUDGE_2_EACH
Q.CABLE_NEG_REPR_JUDGE_4_EACH = CABLE_NEG_REPR_JUDGE_4_EACH
Q.CABLE_NEG_REPR_INFRA_GENEROUS_EACH = CABLE_NEG_REPR_INFRA_GENEROUS_EACH
Q.CABLE_NEG_REPR_INFRA_FAIR_EACH = CABLE_NEG_REPR_INFRA_FAIR_EACH
Q.CABLE_NEG_REPR_EDU_ENROLL_EACH = CABLE_NEG_REPR_EDU_ENROLL_EACH
Q.CABLE_NEG_REPR_EDU_PAY_EACH = CABLE_NEG_REPR_EDU_PAY_EACH
Q.CABLE_NEG_REPR_LAND_TAX_EACH = CABLE_NEG_REPR_LAND_TAX_EACH
Q.CABLE_NEG_PROMISE_BLIND_EYE_RELIEF = CABLE_NEG_PROMISE_BLIND_EYE_RELIEF
Q.CABLE_NEG_PROMISE_RAID_HEAT_RELIEF = CABLE_NEG_PROMISE_RAID_HEAT_RELIEF
Q.CABLE_NEG_PROMISE_DOCKS_DMZ_RELIEF = CABLE_NEG_PROMISE_DOCKS_DMZ_RELIEF
if (Q._cable_neg_api) return
Q._cable_neg_api = 1
Q.cableNegReprisalAdd = function(corp, delta) {
    Q[corp + '_reprisal'] = (Number(Q[corp + '_reprisal']) || 0) + delta
}
Q.cableNegReprisalAddEach = function(delta) {
    Q.cableNegReprisalAdd('soylent', delta)
    Q.cableNegReprisalAdd('magrail', delta)
    Q.cableNegReprisalAdd('brazos', delta)
}
Q.cableNegReprisalSub = function(corp, delta) {
    Q[corp + '_reprisal'] = (Number(Q[corp + '_reprisal']) || 0) - delta
}
Q.cableNegCorpId = function(corp) {
    if (corp === 'soylent') { return 1 }
    if (corp === 'magrail') { return 2 }
    if (corp === 'brazos') { return 3 }
    return 0
}
Q.cableNegCorpName = function(id) {
    id = Number(id) || 0
    if (id === 1) { return 'soylent' }
    if (id === 2) { return 'magrail' }
    if (id === 3) { return 'brazos' }
    return ''
}
Q.cableNegPolicePayReprisalForCorp = function(corp, pay) {
    pay = Number(pay) || 0
    if (pay === 1) { return Q.CABLE_NEG_REPR_PAY_2X_EACH }
    if (pay === 2) { return Q.CABLE_NEG_REPR_PAY_6X_EACH }
    if (pay === 3) { return Q.CABLE_NEG_REPR_PAY_6X_MATCH_EACH }
    if (pay === 4) {
        if (corp === 'soylent') { return Q.CABLE_NEG_REPR_PAY_10X_SOYLENT }
        if (corp === 'magrail') { return Q.CABLE_NEG_REPR_PAY_10X_MAGRAIL }
        if (corp === 'brazos') { return Q.CABLE_NEG_REPR_PAY_10X_BRAZOS }
    }
    return 0
}
Q.cableNegPromiseRelief = function(kind, corp) {
    corp = corp || ''
    if (kind === 'sabotage') { return Math.max(0, Number(Q.sabotage) || 0) }
    if (kind === 'protest') { return Math.max(0, Number(Q.non_violence) || 0) }
    if (kind === 'blind_eye') { return Q.CABLE_NEG_PROMISE_BLIND_EYE_RELIEF }
    if (kind === 'raid_heat') { return Q.CABLE_NEG_PROMISE_RAID_HEAT_RELIEF }
    if (kind === 'docks_dmz') { return Q.CABLE_NEG_PROMISE_DOCKS_DMZ_RELIEF }
    if (kind === 'deeps_tax') {
        return Q.cableNegPolicePayReprisalForCorp(corp, Q.cableNegEffectivePolicePay())
    }
    return 0
}
Q.cableNegPromiseCorpField = function(kind) {
    return 'cable_neg_promise_' + kind + '_corp'
}
Q.cableNegPromiseReliefField = function(kind) {
    return 'cable_neg_promise_' + kind + '_relief'
}
Q.cableNegPromiseTaken = function(kind) {
    return (Number(Q[Q.cableNegPromiseCorpField(kind)]) || 0) > 0
}
Q.cableNegApplyPromise = function(kind, corp) {
    var id = Q.cableNegCorpId(corp)
    if (!id || Q.cableNegPromiseTaken(kind)) { return 0 }
    var relief = Q.cableNegPromiseRelief(kind, corp)
    if (relief <= 0) { return 0 }
    Q[Q.cableNegPromiseCorpField(kind)] = id
    Q[Q.cableNegPromiseReliefField(kind)] = relief
    Q.cableNegReprisalSub(corp, relief)
    if (kind === 'deeps_tax') { Q.cableNegSyncPolicePayReprisal() }
    return relief
}
Q.cableNegClearPromise = function(kind) {
    var id = Number(Q[Q.cableNegPromiseCorpField(kind)]) || 0
    if (id <= 0) { return }
    var corp = Q.cableNegCorpName(id)
    var relief = Number(Q[Q.cableNegPromiseReliefField(kind)]) || 0
    if (relief > 0) { Q.cableNegReprisalAdd(corp, relief) }
    Q[Q.cableNegPromiseCorpField(kind)] = 0
    Q[Q.cableNegPromiseReliefField(kind)] = 0
    if (kind === 'deeps_tax') { Q.cableNegSyncPolicePayReprisal() }
}
Q.cableNegDeepsTaxCorp = function() {
    return Q.cableNegCorpName(Number(Q.cable_neg_promise_deeps_tax_corp) || 0)
}
Q.cableNegPersistPromises = function() {
    var kinds = ['sabotage', 'protest', 'blind_eye', 'raid_heat', 'deeps_tax', 'docks_dmz']
    var i, kind, id, corp, relief
    for (i = 0; i < kinds.length; i++) {
        kind = kinds[i]
        id = Number(Q[Q.cableNegPromiseCorpField(kind)]) || 0
        corp = Q.cableNegCorpName(id)
        relief = Number(Q[Q.cableNegPromiseReliefField(kind)]) || 0
        Q['cable_promise_' + kind + '_corp'] = corp
        Q['cable_promise_' + kind + '_relief'] = relief
        if (corp) {
            Q['cable_promise_block_' + kind + '_' + corp] = 1
        }
    }
    if ((Number(Q.cable_neg_promise_blind_eye_corp) || 0) > 0) {
        Q.cable_break_peace_frail = 1
        Q.cable_promise_blind_eye_due_month = (Number(Q.month) || 0) + 1
        Q.cable_promise_blind_eye_due_year = Number(Q.year) || 0
        if (Q.cable_promise_blind_eye_due_month > 12) {
            Q.cable_promise_blind_eye_due_month -= 12
            Q.cable_promise_blind_eye_due_year += 1
        }
        Q.cable_syndicate_blind_eye_pending = 1
        Q.cable_promise_blind_eye_event_done = 0
        Q.cable_promise_blind_eye_event_ready = 0
    }
    if ((Number(Q.cable_neg_promise_raid_heat_corp) || 0) > 0) {
        Q.cable_promise_raid_heat_due_month = (Number(Q.month) || 0) + 3
        Q.cable_promise_raid_heat_due_year = Number(Q.year) || 0
        while (Q.cable_promise_raid_heat_due_month > 12) {
            Q.cable_promise_raid_heat_due_month -= 12
            Q.cable_promise_raid_heat_due_year += 1
        }
        Q.cable_syndicate_raid_heat_pending = 1
        Q.cable_syndicate_raid_heat_corp_id = Number(Q.cable_neg_promise_raid_heat_corp) || 0
        Q.cable_promise_raid_heat_event_done = 0
        Q.cable_promise_raid_heat_event_ready = 0
    }
    corp = Q.cableNegDeepsTaxCorp()
    if (corp) {
        Q.cable_deeps_tax_burden = Number(Q.cable_neg_promise_deeps_tax_relief) || 0
    }
    corp = Q.cableNegCorpName(Number(Q.cable_neg_promise_docks_dmz_corp) || 0)
    if (corp) {
        Q.cable_docks_dmz_favor = 1
        Q.cable_docks_dmz_favor_corp = corp
        if (corp === 'brazos') { Q.cable_break_peace_frail = 1 }
    }
}
Q.cableNegBreakPromise = function(kind) {
    var corp = Q['cable_promise_' + kind + '_corp']
    var relief = Number(Q['cable_promise_' + kind + '_relief']) || 0
    if (!corp || relief <= 0 || Q['cable_promise_' + kind + '_broken'] === 1) { return }
    Q['cable_promise_' + kind + '_broken'] = 1
    Q.cableNegReprisalAdd(corp, relief * 2)
    if (Q['cable_promise_block_' + kind + '_' + corp] === 1) {
        Q['cable_promise_block_' + kind + '_' + corp] = 0
    }
    if (kind === 'deeps_tax') { Q.cable_deeps_tax_burden = 0 }
    if (kind === 'docks_dmz') {
        Q.cable_docks_dmz_favor = 0
        Q.cable_docks_dmz_favor_corp = ''
    }
}
Q.cableNegPromiseMonthlyTick = function() {
    if (Q.cable_break_peace !== 1) { return }
    var m = Number(Q.month) || 0
    var y = Number(Q.year) || 0
    if (Q.cable_syndicate_blind_eye_pending === 1
        && Q.cable_promise_blind_eye_honored !== 1
        && Q.cable_promise_blind_eye_event_done !== 1
        && m === (Number(Q.cable_promise_blind_eye_due_month) || 0)
        && y === (Number(Q.cable_promise_blind_eye_due_year) || 0)) {
        Q.cable_promise_blind_eye_event_ready = 1
    }
    if (Q.cable_syndicate_raid_heat_pending === 1
        && Q.cable_promise_raid_heat_honored !== 1
        && Q.cable_promise_raid_heat_event_done !== 1
        && m === (Number(Q.cable_promise_raid_heat_due_month) || 0)
        && y === (Number(Q.cable_promise_raid_heat_due_year) || 0)) {
        Q.cable_promise_raid_heat_event_ready = 1
    }
}
Q.cableNegBumpIgProsperity = function(igName, delta) {
    var key = 'prosperity_' + String(igName).toLowerCase()
    var lo = Q.prosperityClampMin != null ? Q.prosperityClampMin : 0
    var hi = Q.prosperityClampMax != null ? Q.prosperityClampMax : 20
    var v = Number(Q[key])
    if (isNaN(v)) { v = 10 }
    Q[key] = Math.max(lo, Math.min(hi, v + Number(delta)))
    if (typeof Q.syncProsperityDisplays === 'function') { Q.syncProsperityDisplays() }
}
Q.cableNegRemoveIgAssets = function(owner, district, count) {
    if (typeof Q.ensureEconomicAssets === 'function') { Q.ensureEconomicAssets() }
    if (!Q.economicAssets) { return 0 }
    var removed = 0
    var n = Math.max(0, Number(count) || 0)
    for (var pass = 0; pass < n; pass++) {
        for (var i = Q.economicAssets.length - 1; i >= 0; i--) {
            var e = Q.economicAssets[i]
            if (e.ownerType !== 'ig' || e.owner !== owner) { continue }
            if (e.countsAsHome) { continue }
            if (district && e.district !== district) { continue }
            if (e.health != null && Number(e.health) < 1) { continue }
            Q.economicAssets.splice(i, 1)
            removed += 1
            break
        }
    }
    if (removed > 0 && typeof Q.updateJacobsAssetsReport === 'function') {
        Q.updateJacobsAssetsReport()
    }
    return removed
}
Q.cableNegHonorPromise = function(kind) {
    Q['cable_promise_' + kind + '_honored'] = 1
}
Q.cableNegApplySyndicateBacklash = function(opts) {
    opts = opts || {}
    if (opts.global) {
        Q.cable_syndicate_raid_backlash_global = (Number(Q.cable_syndicate_raid_backlash_global) || 0) + opts.global
    }
    if (opts.docks) {
        Q.cable_syndicate_raid_backlash_docks = (Number(Q.cable_syndicate_raid_backlash_docks) || 0) + opts.docks
    }
    if (opts.deeps) {
        Q.cable_syndicate_raid_backlash_deeps = (Number(Q.cable_syndicate_raid_backlash_deeps) || 0) + opts.deeps
    }
    if (opts.railyard) {
        Q.cable_syndicate_raid_backlash_railyard = (Number(Q.cable_syndicate_raid_backlash_railyard) || 0) + opts.railyard
    }
    if (typeof Q.update_projections === 'function') { Q.update_projections() }
}
Q.cableNegEffectiveRelief = function(downs, grossUp) {
    var i, grossDown = 0, out = []
    downs = downs || []
    if (grossUp < 2) { return out }
    for (i = 0; i < downs.length; i++) {
        if (downs[i].n > 0) { out.push({ corp: downs[i].corp, n: downs[i].n }) }
    }
    for (i = 0; i < out.length; i++) { grossDown += out[i].n }
    if (grossDown >= grossUp) {
        var budget = grossUp - 1
        for (i = 0; i < out.length; i++) {
            if (budget <= 0) { out[i].n = 0 }
            else if (out[i].n > budget) { out[i].n = budget; budget = 0 }
            else { budget -= out[i].n }
        }
    }
    return out
}
Q.cableNegApplyWithRivalRelief = function(ups, downs) {
    var i, grossUp = 0
    ups = ups || []
    for (i = 0; i < ups.length; i++) { grossUp += ups[i].n }
    downs = Q.cableNegEffectiveRelief(downs, grossUp)
    for (i = 0; i < ups.length; i++) { Q.cableNegReprisalAdd(ups[i].corp, ups[i].n) }
    for (i = 0; i < downs.length; i++) {
        if (downs[i].n > 0) { Q.cableNegReprisalSub(downs[i].corp, downs[i].n) }
    }
}
Q.cableNegUndoWithRivalRelief = function(ups, downs) {
    var i, grossUp = 0
    ups = ups || []
    for (i = 0; i < ups.length; i++) { grossUp += ups[i].n }
    downs = Q.cableNegEffectiveRelief(downs, grossUp)
    for (i = 0; i < ups.length; i++) { Q.cableNegReprisalSub(ups[i].corp, ups[i].n) }
    for (i = 0; i < downs.length; i++) {
        if (downs[i].n > 0) { Q.cableNegReprisalAdd(downs[i].corp, downs[i].n) }
    }
}
Q.cableNegApplyVatsPolice = function() {
    Q.cableNegApplyWithRivalRelief(
        [{ corp: 'soylent', n: Q.CABLE_NEG_REPR_VATS_SOYLENT }],
        [{ corp: 'magrail', n: Q.CABLE_NEG_RELIEF_VATS_MAGRAIL }]
    )
}
Q.cableNegClearVatsPolice = function() {
