Q.cableNegClearCorpTax = function() {
    var t = Number(Q.cable_neg_corp_tax) || 0
    if (t === 1) { Q.cableNegClearTaxHalfBelligerents() }
    else if (t === 2) { Q.cableNegClearTaxFullBelligerents() }
    else if (t === 3) {
        Q.cableNegReprisalSub('soylent', Q.CABLE_NEG_REPR_TAX_HALF_ALL_EACH)
        Q.cableNegReprisalSub('magrail', Q.CABLE_NEG_REPR_TAX_HALF_ALL_EACH)
        Q.cableNegReprisalSub('brazos', Q.CABLE_NEG_REPR_TAX_HALF_ALL_EACH)
    } else if (t === 4) {
        Q.cableNegReprisalSub('soylent', Q.CABLE_NEG_REPR_TAX_FULL_ALL_SOYLENT)
        Q.cableNegReprisalSub('magrail', Q.CABLE_NEG_REPR_TAX_FULL_ALL_MAGRAIL)
        Q.cableNegReprisalSub('brazos', Q.CABLE_NEG_REPR_TAX_FULL_ALL_BRAZOS)
    }
    Q.cable_neg_corp_tax = 0
    Q.cable_neg_corp_tax_fund = 0
    Q.cable_neg_brazos_tax_exempt = 0
}
Q.cableNegHasPoliceTransfer = function() {
    return Q.cable_neg_police_vats === 1 || Q.cable_neg_police_railyard === 1
        || Q.cable_neg_police_docks === 1 || Q.cable_neg_police_limelight === 1
}
Q.cableNegEffectivePolicePay = function() {
    var pay = Number(Q.cable_neg_police_pay) || 0
    if (pay > 0) { return pay }
    return Q.cableNegHasPoliceTransfer() ? 1 : 0
}
Q.cableNegApplyPolicePayReprisal = function(pay) {
    pay = Number(pay) || 0
    var corps = ['soylent', 'magrail', 'brazos']
    var deepsCorp = Q.cableNegDeepsTaxCorp()
    var i, corp, n
    if (pay >= 1 && pay <= 3) {
        n = pay === 1 ? Q.CABLE_NEG_REPR_PAY_2X_EACH
            : (pay === 2 ? Q.CABLE_NEG_REPR_PAY_6X_EACH : Q.CABLE_NEG_REPR_PAY_6X_MATCH_EACH)
        for (i = 0; i < corps.length; i++) {
            corp = corps[i]
            if (corp === deepsCorp) { continue }
            Q.cableNegReprisalAdd(corp, n)
        }
    } else if (pay === 4) {
        for (i = 0; i < corps.length; i++) {
            corp = corps[i]
            if (corp === deepsCorp) { continue }
            Q.cableNegReprisalAdd(corp, Q.cableNegPolicePayReprisalForCorp(corp, pay))
        }
    }
}
Q.cableNegClearPolicePayReprisal = function(pay) {
    pay = Number(pay) || 0
    var corps = ['soylent', 'magrail', 'brazos']
    var deepsCorp = Q.cableNegDeepsTaxCorp()
    var i, corp, n
    if (pay >= 1 && pay <= 3) {
        n = pay === 1 ? Q.CABLE_NEG_REPR_PAY_2X_EACH
            : (pay === 2 ? Q.CABLE_NEG_REPR_PAY_6X_EACH : Q.CABLE_NEG_REPR_PAY_6X_MATCH_EACH)
        for (i = 0; i < corps.length; i++) {
            corp = corps[i]
            if (corp === deepsCorp) { continue }
            Q.cableNegReprisalSub(corp, n)
        }
    } else if (pay === 4) {
        for (i = 0; i < corps.length; i++) {
            corp = corps[i]
            if (corp === deepsCorp) { continue }
            Q.cableNegReprisalSub(corp, Q.cableNegPolicePayReprisalForCorp(corp, pay))
        }
    }
}
Q.cableNegSyncPolicePayReprisal = function() {
    var effective = Q.cableNegEffectivePolicePay()
    var applied = Number(Q.cable_neg_police_pay_applied) || 0
    Q.cable_neg_police_pay_effective = effective
    if (effective === applied) { return }
    if (applied > 0) { Q.cableNegClearPolicePayReprisal(applied) }
    if (effective > 0) { Q.cableNegApplyPolicePayReprisal(effective) }
    Q.cable_neg_police_pay_applied = effective
}
Q.cableNegClearPolicePay = function() {
    Q.cable_neg_police_pay = 0
    if ((Number(Q.cable_neg_corp_tax) || 0) > 0) { Q.cableNegClearCorpTax() }
    Q.cableNegSyncPolicePayReprisal()
}
Q.cableNegClearJudgeReview = function() {
    var j = Number(Q.cable_neg_judge_review) || 0
    if (j === 2) {
        Q.cableNegReprisalSub('soylent', Q.CABLE_NEG_REPR_JUDGE_2_EACH)
        Q.cableNegReprisalSub('magrail', Q.CABLE_NEG_REPR_JUDGE_2_EACH)
        Q.cableNegReprisalSub('brazos', Q.CABLE_NEG_REPR_JUDGE_2_EACH)
    } else if (j === 4) {
        Q.cableNegReprisalSub('soylent', Q.CABLE_NEG_REPR_JUDGE_4_EACH)
        Q.cableNegReprisalSub('magrail', Q.CABLE_NEG_REPR_JUDGE_4_EACH)
        Q.cableNegReprisalSub('brazos', Q.CABLE_NEG_REPR_JUDGE_4_EACH)
    }
    Q.cable_neg_judge_review = 0
}
Q.cableNegClearTrials = function() {
    if ((Number(Q.cable_neg_judge_review) || 0) > 0) { Q.cableNegClearJudgeReview() }
    var t = Number(Q.cable_neg_trials) || 0
    if (t === 1) {
        Q.cableNegReprisalSub('soylent', Q.CABLE_NEG_REPR_TRIALS_CITY_SOYLENT)
        Q.cableNegReprisalSub('magrail', Q.CABLE_NEG_REPR_TRIALS_CITY_MAGRAIL)
        Q.cableNegReprisalSub('brazos', Q.CABLE_NEG_REPR_TRIALS_CITY_BRAZOS)
    } else if (t === 2) {
        Q.cableNegClearTrialsMixed()
    }
    Q.cable_neg_trials = 0
}
Q.cableNegClearEducationPayCorp = function(corp) {
    if (Q['cable_neg_' + corp + '_education_pay'] === 1) {
        Q.cableNegReprisalSub(corp, Q.CABLE_NEG_REPR_EDU_PAY_EACH)
        Q['cable_neg_' + corp + '_education_pay'] = 0
    }
}
Q.cableNegClearEducationEnrollCorp = function(corp) {
    Q.cableNegClearEducationPayCorp(corp)
    if (Q['cable_neg_' + corp + '_education_enroll'] === 1) {
        Q.cableNegReprisalSub(corp, Q.CABLE_NEG_REPR_EDU_ENROLL_EACH)
        Q['cable_neg_' + corp + '_education_enroll'] = 0
    }
}
Q.cableNegClearLandTaxCorp = function(corp) {
    if (Q['cable_neg_' + corp + '_land_tax'] === 1) {
        Q.cableNegReprisalSub(corp, Q.CABLE_NEG_REPR_LAND_TAX_EACH)
        Q['cable_neg_' + corp + '_land_tax'] = 0
    }
}
Q.cableNegSyncCorpStances = function() {
    function stanceFor(corp) {
        var margin = (Number(Q[corp + '_leverage']) || 0) - (Number(Q[corp + '_reprisal']) || 0)
        var cat = 1
        if (margin > 3) { cat = 4 }
        else if (margin >= 2) { cat = 3 }
        else if (margin >= 1) { cat = 2 }
        Q['cable_neg_stance_' + corp] = cat
    }
    stanceFor('soylent')
    stanceFor('magrail')
    stanceFor('brazos')
}
}
Q.cableNegEnsureApi()
if (Q.cable_neg_ready != 1) {
    Q.cable_neg_ready = 1
    Q.cable_neg_leverage_boost = Q.cableNegLeverageBoost
    Q.soylent_leverage = (Number(Q.soylent_leverage) || 0) + Q.cable_neg_leverage_boost
    Q.magrail_leverage = (Number(Q.magrail_leverage) || 0) + Q.cable_neg_leverage_boost
    Q.brazos_leverage = (Number(Q.brazos_leverage) || 0) + Q.cable_neg_leverage_boost
    Q.soylent_reprisal = (Number(Q.soylent_reprisal) || 0) - CABLE_NEG_OPENING_REPRISAL_RELIEF
    Q.magrail_reprisal = (Number(Q.magrail_reprisal) || 0) - CABLE_NEG_OPENING_REPRISAL_RELIEF
    Q.brazos_reprisal = (Number(Q.brazos_reprisal) || 0) - CABLE_NEG_OPENING_REPRISAL_RELIEF

    Q.cable_neg_prior_soylent = (Number(Q.soylent_leverage) || 0) > Q.cable_neg_leverage_boost ? 1 : 0
    Q.cable_neg_prior_magrail = (Number(Q.magrail_leverage) || 0) > Q.cable_neg_leverage_boost ? 1 : 0
    Q.cable_neg_prior_brazos = (Number(Q.brazos_leverage) || 0) > Q.cable_neg_leverage_boost ? 1 : 0
    Q.cable_neg_prior_leverage = (
        Q.cable_neg_prior_soylent === 1
        || Q.cable_neg_prior_magrail === 1
        || Q.cable_neg_prior_brazos === 1
    ) ? 1 : 0

    Q.cable_neg_police_vats = 0
    Q.cable_neg_police_railyard = 0
